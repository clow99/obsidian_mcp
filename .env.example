# Copy this file to .env and update the host vault path before running Docker.
OBSIDIAN_VAULT_HOST_PATH=C:/path/to/your/obsidian-vault
OBSIDIAN_VAULT_PATH=/vault
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=
OBSIDIAN_TEMPLATE_FOLDER=Templates
OBSIDIAN_ATTACHMENTS_FOLDER=Assets
OBSIDIAN_DAILY_NOTES_FOLDER=Daily Notes
OBSIDIAN_DEFAULT_NOTE_FOLDER=Inbox
OBSIDIAN_NOTE_EXTENSION=.md
OBSIDIAN_ALLOW_UNSAFE_OVERWRITE=false
OBSIDIAN_SEMANTIC_INDEX_FOLDER=.obsidian-mcp/semantic-index
OBSIDIAN_SEMANTIC_EMBEDDING_MODEL=text-embedding-3-small
OBSIDIAN_SEMANTIC_CHUNK_SIZE=1200
OBSIDIAN_SEMANTIC_CHUNK_OVERLAP=200
OBSIDIAN_SEMANTIC_TOP_K=8
OBSIDIAN_SEMANTIC_BATCH_SIZE=50
